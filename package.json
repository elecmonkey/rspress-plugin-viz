{
  "name": "rspress-plugin-viz",
  "version": "0.2.1",
  "description": "Add Graphviz support for Rspress using @viz-js/viz.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "static"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "lint": "rslint . --type-check",
    "docs:dev": "rspress dev",
    "docs:build": "rspress build",
    "docs:preview": "rspress preview"
  },
  "keywords": [
    "rspress",
    "plugin",
    "viz",
    "graphviz",
    "dot"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@rspress/core": "^2.0.0",
    "@viz-js/viz": "^3.24.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@rslib/core": "^0.23.1",
    "@rslint/core": "^0.6.3",
    "@rspress/core": "^2.0.15",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@viz-js/viz": "^3.28.0",
    "mdast-util-mdx-jsx": "^3.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "unified": "^11.0.5",
    "wrangler": "4.99.0"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=11.5.2"
  },
  "author": "Elecmonkey",
  "repository": {
    "type": "git",
    "url": "https://github.com/elecmonkey/rspress-plugin-viz"
  },
  "homepage": "https://rspress-plugin-viz.edev.uno/"
}
